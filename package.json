{
  "name": "shiftleft-qa",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5",
    "node": ">=20.0.0"
  },
  "scripts": {
    "check": "bun run lint && bun run typecheck && bun run test",
    "dev": "bun run src/exploratory-testing/cli/index.ts",
    "doctor": "bun run src/exploratory-testing/cli/index.ts doctor",
    "format": "biome check --write .",
    "lint": "biome check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "execa": "^9.6.0",
    "gray-matter": "^4.0.3",
    "tinyglobby": "^0.2.14",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.14.1",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
